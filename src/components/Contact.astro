---
// Edit these to your real contact details
const email = 'alexmax.pienkowski@gmail.com';
const github = 'https://github.com/05blue04';
const linkedin = 'https://www.linkedin.com/in/alex-pienkowski2727/';
---

<section id="contact" class="py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Get In Touch</h2>
    <p class="text-gray-500 max-w-md mx-auto mb-10">
      Whether you have a question, a project idea, or just want to say hi — my inbox is open.
    </p>

    <a
      href="mailto:alexmax.pienkowski@gmail.com"
      class="inline-flex items-center px-8 py-4 bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors mb-4"
    >
      Say Hello
    </a>

    <p class="text-sm text-gray-400 mb-10">
      or email me directly at
      <a href="mailto:alexmax.pienkowski@gmail.com" class="text-gray-600 hover:text-gray-900 underline">
        alexmax.pienkowski@gmail.com
      </a>
    </p>

    <div class="flex justify-center gap-8 text-sm text-gray-500">
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-900 transition-colors"
      >
        GitHub
      </a>
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-900 transition-colors"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>
